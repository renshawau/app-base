{
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types", "vite/client"],
    "paths": {
      "@app-base/auth": ["../../packages/auth/src/index.ts"],
      "@app-base/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": ["src"]
}
